@model KnapTask.Models.TaskItem

@{
    ViewData["Title"] = "Новая задача";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow border-0 p-3">
                <div class="card-body">
                    <h3 class="card-title text-center text-primary fw-bold mb-4">
                        <i class="bi bi-plus-circle"></i> Создать задачу
                    </h3>
                    
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="form-floating mb-3">
                            <input asp-for="Title" class="form-control form-control-lg" placeholder="Например: Сдать курсовую" />
                            <label asp-for="Title">Что нужно сделать?</label>
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>
                        
                        <div class="row mb-3 g-2">
                            <div class="col-md-6 form-floating">
                                <input asp-for="Weight" class="form-control" type="number" placeholder="4" min="1" />
                                <label asp-for="Weight">Время (часов)</label>
                                <span asp-validation-for="Weight" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 form-floating">
                                <input asp-for="Value" class="form-control" type="number" placeholder="10" min="1" max="10" />
                                <label asp-for="Value">Польза (1-10)</label>
                                <span asp-validation-for="Value" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-floating mb-3">
                            <select asp-for="Category" class="form-select">
                                <option value="Учеба">Учеба 📚</option>
                                <option value="Работа">Работа 💼</option>
                                <option value="Личное">Личное 🏠</option>
                                <option value="Спорт">Спорт 👟</option>
                                <option value="Другое">Другое ⚙️</option>
                            </select>
                            <label asp-for="Category">В какую сферу это входит?</label>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                                <i class="bi bi-check2-circle"></i> Запланировать!
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm mt-1">Назад к списку</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
