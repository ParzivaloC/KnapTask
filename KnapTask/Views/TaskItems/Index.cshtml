@model IEnumerable<KnapTask.Models.TaskItem>

@{
    ViewData["Title"] = "Твои Задачи";
}

<div class="container mt-4">
    <div class="row align-items-center mb-4">
        <div class="col-md-8">
            <h1 class="display-5 fw-bold text-dark">Привет! Давай запланируем задачи.</h1>
            <p class="lead text-muted">Сегодня отличный день, чтобы выполнить пару важных дел.</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
                <i class="bi bi-plus-circle"></i> Добавить задачу
            </a>
        </div>
    </div>

    <div class="row mb-4 g-3">
        <div class="col-md-7">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title text-muted mb-0">Общий прогресс</h5>
                        <span class="fs-4 fw-bold text-success">@ViewBag.ProgressPercent%</span>
                    </div>
                    <div class="progress" style="height: 25px;">
                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-success"
                             style="width: @ViewBag.ProgressPercent%"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card h-100 shadow-sm border-0 bg-light">
                <div class="card-body">
                    <h5 class="card-title text-primary"><i class="bi bi-cpu"></i> Умный план</h5>
                    <form asp-action="Plan" method="get" class="row g-2">
                        <div class="col">
                            <input type="number" name="hours" class="form-control" placeholder="Часов?" value="8">
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-primary">Рассчитать</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-5">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Задача</th>
                        <th>Категория</th>
                        <th class="text-center">Часы</th>
                        <th class="text-center">Важность</th>
                        <th class="text-center">V/W</th>
                        <th class="text-center">Статус</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        double efficiency = item.Weight > 0 ? (double)item.Value / item.Weight : 0;
                        string badgeColor = item.Category switch
                        {
                            "Учеба" => "bg-info",
                            "Работа" => "bg-warning text-dark",
                            "Спорт" => "bg-danger",
                            _ => "bg-secondary"
                        };

                        <tr>
                            <td class="fw-bold">@item.Title</td>
                            <td><span class="badge @badgeColor">@item.Category</span></td>
                            <td class="text-center">@item.Weight</td>
                            <td class="text-center"><span class="badge bg-light text-primary border">@item.Value</span></td>
                            <td class="text-center fw-bold text-info">@efficiency.ToString("F2")</td>
                            <td class="text-center">
                                <form asp-action="ToggleStatus" asp-route-id="@item.Id" method="post">
                                    <button type="submit" class="btn btn-sm @(item.IsCompleted ? "btn-success" : "btn-outline-secondary") w-100">
                                        <i class="bi @(item.IsCompleted ? "bi-check-circle" : "bi-circle")"></i>
                                        @(item.IsCompleted ? "Готово" : "В процессе")
                                    </button>
                                </form>
                            </td>
                            <td class="text-end">
                                <div class="btn-group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm border-0 p-4">
        <div class="row">
            <div class="col-md-6 border-end">
                <canvas id="priorityChart" style="max-height: 250px;"></canvas>
            </div>
            <div class="col-md-6">
                <canvas id="categoryPieChart" style="max-height: 250px;"></canvas>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const ctx = document.getElementById('priorityChart').getContext('2d');
    new Chart(ctx, {
    type: 'bar', // Тип графика: столбчатая диаграмма
    data: {
    labels: @Html.Raw(Json.Serialize(ViewBag.StatLabels)),
    datasets: 
    [{
    label: 'Количество задач',

    data: @Html.Raw(Json.Serialize(ViewBag.StatData)),

    backgroundColor: 'rgba(54, 162, 235, 0.5)',

    borderColor: 'rgba(54, 162, 235, 1)',

    borderWidth: 1

    }]
    },
    options: {
    scales: 
    {y: 
        { beginAtZero: true, ticks: { stepSize: 1 } }
    }
    }
    });

    const ctxPie = document.getElementById('categoryPieChart').getContext('2d');
    new Chart(ctxPie, {
    type: 'pie',
    data: {
    labels: @Html.Raw(Json.Serialize(ViewBag.CategoryLabels)),
    datasets: [{
    data: @Html.Raw(Json.Serialize(ViewBag.CategoryData)),
    backgroundColor: [
    '#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF'
    ]
    }]
    }
    });

</script>