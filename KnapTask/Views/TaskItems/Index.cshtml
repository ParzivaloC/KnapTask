@model IEnumerable<KnapTask.Models.TaskItem>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<div class="card mb-4 border-primary">
    <div class="card-body">
        <h5 class="card-title">Сформировать план на день</h5>
        <form asp-action="Plan" method="get" class="row g-3">
            <div class="col-auto">
                <label class="visually-hidden">Часы</label>
                <input type="number" name="hours" class="form-control" placeholder="Сколько часов есть?" value="8">
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-success">Рассчитать алгоритмом</button>
            </div>
        </form>
    </div>
</div>

<div class="mb-4">
    <div class="d-flex justify-content-between mb-1">
        <span>Общий прогресс выполнения</span>
        <span>@ViewBag.ProgressPercent%</span>
    </div>
    <div class="progress" style="height: 25px;">
        <div class="progress-bar progress-bar-striped progress-bar-animated bg-success"
             role="progressbar"
             style="width: @ViewBag.ProgressPercent%"
             aria-valuenow="@ViewBag.ProgressPercent"
             aria-valuemin="0"
             aria-valuemax="100">
        </div>
    </div>
</div>


<p>
    <a asp-action="Create">Создать новую задачу</a>
</p>
<table class="table table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>Задача</th>
            <th>Описание</th>
            <th>Время (ч)</th>
            <th>Важность</th>
            <th>Эффективность (V/W)</th>
            <th>Статус</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            // Считаем эффективность здесь
            double efficiency = item.Weight > 0 ? (double)item.Value / item.Weight : 0;

            <tr>
                <td class="fw-bold">@item.Title</td>
                <td class="text-muted">@item.Description</td>
                <td>@item.Weight</td>
                <td>
                    <span class="badge bg-primary">@item.Value</span>
                </td>
                <td class="fw-bold text-info">
                    @efficiency.ToString("F2")
                </td>
                <td>
                    <form asp-controller="TaskItems" asp-action="ToggleStatus" asp-route-id="@item.Id" method="post">
                        <button type="submit" class="btn btn-sm @(item.IsCompleted ? "btn-success" : "btn-outline-secondary")">
                            @(item.IsCompleted ? "Выполнено" : "В процессе")
                        </button>
                    </form>
                </td>
                <td>
                    <div class="btn-group" role="group">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Ред.</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Детали</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Удалить</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

<hr />
<div class="row mt-5">
    <div class="col-md-6">
        <h3>Анализ приоритетов</h3>
        <canvas id="priorityChart" width="400" height="200"></canvas>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const ctx = document.getElementById('priorityChart').getContext('2d');
    new Chart(ctx, {
    type: 'bar', // Тип графика: столбчатая диаграмма
    data: {
    labels: @Html.Raw(Json.Serialize(ViewBag.StatLabels)),
    datasets: 
    [{
    label: 'Количество задач',

    data: @Html.Raw(Json.Serialize(ViewBag.StatData)),

    backgroundColor: 'rgba(54, 162, 235, 0.5)',

    borderColor: 'rgba(54, 162, 235, 1)',

    borderWidth: 1

    }]
    },
    options: {
    scales: 
    {y: 
        { beginAtZero: true, ticks: { stepSize: 1 } }
    }
    }
    });
</script>